# =============================================================================
# Environment variables template for go-bybit examples.
#
# Usage:
#   1. Copy this file next to itself without the .example suffix:
#        cp .env.example .env
#   2. Fill in the real values in .env. KEEP .env OUT OF GIT.
#   3. Run any example via the helper script:
#        ./scripts/run.sh ./examples/account-info
#      …or by sourcing the file manually:
#        set -a; source .env; set +a
#        go run ./examples/simple-trade
#
# WARNING:
#   - .env is listed in .gitignore — never commit it.
#   - If a real key leaks into git: revoke it on Bybit and rotate.
#   - Never paste the contents of .env into AI chats, screenshots, or issues.
#
# RECOMMENDED FIRST STEPS:
#   - Use Bybit TESTNET for the first round of testing
#     (BYBIT_TESTNET=1, see below). Testnet keys are issued separately at
#     https://testnet.bybit.com — they do NOT work against production.
#   - Trade SMALL amounts (BYBIT_QUANTITY=0.001 for BTCUSDT etc.).
#   - The trading examples (simple-trade, inventory-tracker) refuse to run
#     against production unless BYBIT_ALLOW_LIVE=1 is set explicitly.
# =============================================================================

# --- Required for private calls (Trading, Account, WS-private) ---

# API Key issued by Bybit (production OR testnet — see BYBIT_TESTNET below).
BYBIT_API_KEY=

# API Secret used to compute X-BAPI-SIGN.
BYBIT_API_SECRET=

# --- Endpoint switch (pick at most ONE) ---

# 1 = use Bybit TESTNET (api-testnet.bybit.com / stream-testnet.bybit.com).
#     Recommended for first runs of trading examples.
BYBIT_TESTNET=0

# 1 = use Bybit DEMO trading (api-demo.bybit.com). Demo keys are issued
#     separately in the Bybit web UI; DEMO and production keys are NOT
#     interchangeable. Demo public WS shares production market data.
BYBIT_DEMO=0

# --- Common per-example overrides (all optional) ---

# Symbol for every example. Default: BTCUSDT.
BYBIT_SYMBOL=BTCUSDT

# Order quantity in BASE asset (BTC, ETH, ...). Default depends on the
# example (typically 0.001 for BTCUSDT, well above MinOrderQty=0.001).
BYBIT_QUANTITY=0.001

# Maximum hold time in seconds for inventory-tracker (default 5).
BYBIT_HOLD_SECONDS=5

# --- Trading guard ---

# Required to be 1 for examples that send live orders against PRODUCTION.
# When BYBIT_TESTNET=1 or BYBIT_DEMO=1 the guard is bypassed automatically.
BYBIT_ALLOW_LIVE=0
